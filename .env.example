# Relay Directory Overlay — Environment Variables
# Copy this to .env and fill in your values

# Required: overlay identity key (generated by `node cli.js init`)
OVERLAY_WIF=

# Required: public domain of this overlay node
OVERLAY_DOMAIN=vmi2946361.contaboserver.net

# Server config
OVERLAY_PORT=3360
OVERLAY_DB_PATH=./data/directory.db

# Peer overlay nodes for sync (comma-separated URLs, empty = standalone)
OVERLAY_PEERS=

# Peer overlay node identity pubkeys for auth (comma-separated hex, empty = self only)
OVERLAY_PEER_PUBKEYS=

# Relay bridge URL for on-chain tx verification (default: http://127.0.0.1:9333)
OVERLAY_BRIDGE_URL=http://127.0.0.1:9333

# CORS origins (comma-separated, empty = allow all in dev)
OVERLAY_CORS_ORIGINS=

# Pricing (satoshis per request, 0 = free)
OVERLAY_PRICE_SUBMIT=0
OVERLAY_PRICE_LOOKUP=0
OVERLAY_PRICE_REVOKE=0
